{
  "manifest_version": 3,
  "name": "Tab Cleaner",
  "version": "1.0.0",
  "description": "Groups tabs by domain and removes duplicates, keeping one tab per domain.",
  "permissions": ["tabs", "tabGroups"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
